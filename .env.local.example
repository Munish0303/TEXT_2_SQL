# --- Supabase Postgres connection string ---
# Supabase dashboard -> Project Settings -> Database -> Connection string ->
# choose "Connection pooling" (Transaction mode, port 6543). It looks like:
# postgresql://postgres.abcdefgh:YOUR-PASSWORD@aws-0-xx.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Groq API key (free) ---
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the Groq model (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
